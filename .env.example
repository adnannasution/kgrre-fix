# Salin file ini menjadi `.env` lalu isi nilai aslinya.
# `.env` sudah masuk .gitignore — JANGAN commit nilai rahasia.

# Koneksi PostgreSQL.
# - Untuk DEV LOKAL (dari laptop): pakai nilai DATABASE_PUBLIC_URL dari Railway
#   (host *.proxy.rlwy.net). Backend akan connect ke PostgreSQL Railway via internet.
# - Saat sudah DEPLOY di Railway: variabel DATABASE_URL otomatis disuntikkan Railway
#   (host *.railway.internal), tidak perlu di-set di sini.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DBNAME

# Port HTTP server (opsional untuk dev; di Railway diisi otomatis lewat $PORT).
PORT=8765
